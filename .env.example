# =============================================================================
#  CBT SCHOOL ENTERPRISE — ENVIRONMENT TEMPLATE
#  COPY FILE INI KE .env DAN ISI NILAINYA
#  ⚠️  JANGAN COMMIT FILE .env KE GIT
# =============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE CORE CREDENTIALS
# ------------------------------------------------------------------------------
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_PASSWORD=your_strong_postgres_password_here

# Connection Pooling
POSTGRES_MAX_CONNECTIONS=200
PGRST_DB_POOL=20

# ------------------------------------------------------------------------------
# 2. AUTHENTICATION & SECURITY (JWT)
# Gunakan: openssl rand -base64 32 untuk generate JWT_SECRET
# ------------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_EXPIRY=3600

# Auth Redirect
GOTRUE_SITE_URL=http://YOUR_SERVER_IP:8000
GOTRUE_URI_ALLOW_LIST=*
GOTRUE_DISABLE_SIGNUP=false

# ------------------------------------------------------------------------------
# 3. API GATEWAY & NETWORK
# Ganti YOUR_SERVER_IP dengan IP static sekolah
# ------------------------------------------------------------------------------
PORT=8000
API_EXTERNAL_URL=http://YOUR_SERVER_IP:8000
SUPABASE_PUBLIC_URL=http://YOUR_SERVER_IP:8000

# ------------------------------------------------------------------------------
# 4. API KEYS
# Generate dengan: https://supabase.com/docs/guides/self-hosting#api-keys
# atau gunakan script: scripts/generate-keys.sh
# ------------------------------------------------------------------------------
ANON_KEY=your_anon_key_jwt_here
SERVICE_ROLE_KEY=your_service_role_key_jwt_here

# ------------------------------------------------------------------------------
# 5. FRONTEND INTEGRATION
# ------------------------------------------------------------------------------
VITE_SUPABASE_URL=http://YOUR_SERVER_IP:8000
VITE_SUPABASE_ANON_KEY=your_anon_key_jwt_here

NEXT_PUBLIC_SUPABASE_URL=http://YOUR_SERVER_IP:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_jwt_here

# ------------------------------------------------------------------------------
# 6. DASHBOARD CONFIGURATION (Studio)
# ------------------------------------------------------------------------------
STUDIO_DEFAULT_ORGANIZATION=CBT School Enterprise
STUDIO_DEFAULT_PROJECT=cbt-school
STUDIO_PORT=3000
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_secure_dashboard_password_here

# ------------------------------------------------------------------------------
# 7. PERFORMANCE TUNING
# ------------------------------------------------------------------------------
PGRST_DB_MAX_ROWS=100000
STATEMENT_TIMEOUT=10000
FILE_SIZE_LIMIT=52428800

# ------------------------------------------------------------------------------
# 8. SUPABASE ADVANCED
# ------------------------------------------------------------------------------
SNIPPETS_MANAGEMENT_FOLDER=/var/lib/snippets
GRAPHQL_ENABLED=false
PGRST_OPENAPI_SERVER_PROXY_URI=http://YOUR_SERVER_IP:8000
PGRST_OPENAPI_SECURITY_ACTIVE=true
PGRST_JWT_CACHE_MAX_LIFETIME=300
