# =============================================================================
#  CBT SCHOOL ENTERPRISE — .gitignore
#  Security Level: Enterprise (Zero-Leak Policy)
#  Maintainer: Ari Wijaya
#  Updated: 2026-02-28
# =============================================================================

# ------------------------------------------------------------------------------
# [CRITICAL] ENVIRONMENT & SECRETS — NEVER COMMIT
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env
.envrc
secrets/
*.secret
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr

# ------------------------------------------------------------------------------
# [CRITICAL] SUPABASE DATABASE VOLUMES (Raw PG Data — Bisa 10GB+)
# ------------------------------------------------------------------------------
supabase/volumes/db/data/
supabase/volumes/storage/
supabase/volumes/api/
supabase/volumes/logs/
supabase/volumes/studio/snippets/
# Simpan hanya file konfigurasi volumes, bukan datanya
!supabase/volumes/db/init/
!supabase/volumes/api/kong.yml

# ------------------------------------------------------------------------------
# NODE.JS — Dependencies & Build Artifacts
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build output
dist/
dist-ssr/
build/
.output/
out/

# Cache
.vite/
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/

# ------------------------------------------------------------------------------
# TYPESCRIPT
# ------------------------------------------------------------------------------
*.tsbuildinfo
.tsc-cache/

# ------------------------------------------------------------------------------
# DATABASE BACKUP FILES (Simpan di server, bukan di repo)
# ------------------------------------------------------------------------------
*.sql.gz
*.dump
*.backup
*.bak
backups/
db_backups/

# ------------------------------------------------------------------------------
# LOGS
# ------------------------------------------------------------------------------
logs/
*.log
*.log.*
npm-debug.log
yarn-debug.log

# ------------------------------------------------------------------------------
# OS GENERATED FILES
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V4
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ------------------------------------------------------------------------------
# EDITOR / IDE
# ------------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.project
.classpath

# Claude Code IDE configuration (local only, jangan di-commit)
.claude/
**/.claude/

# ------------------------------------------------------------------------------
# DOCKER — Tidak commit data volume lokal
# ------------------------------------------------------------------------------
docker-data/
.docker/

# ------------------------------------------------------------------------------
# NGINX — Jangan commit credential htpasswd
# ------------------------------------------------------------------------------
*.htpasswd
nginx/*.htpasswd

# ------------------------------------------------------------------------------
# TEMPORARY & TEST FILES
# ------------------------------------------------------------------------------
tmp/
temp/
.tmp/
*.tmp
coverage/
.nyc_output/
junit.xml
test-results/

# ------------------------------------------------------------------------------
# PACKAGE LOCKS (gunakan salah satu saja, konsisten)
# Jika menggunakan npm: keep package-lock.json, ignore yarn.lock
# Jika menggunakan yarn: keep yarn.lock, ignore package-lock.json
# ------------------------------------------------------------------------------
# yarn.lock
# package-lock.json

# ------------------------------------------------------------------------------
# CERTIFICATE & SECURITY
# ------------------------------------------------------------------------------
ssl/
certs/
*.p8

# ------------------------------------------------------------------------------
# MEDIA & UPLOADS (Jangan simpan di repo, gunakan Supabase Storage)
# ------------------------------------------------------------------------------
uploads/
public/uploads/
storage/

# ------------------------------------------------------------------------------
# GENERATED / AUTO-CREATED
# ------------------------------------------------------------------------------
*.generated.*
auto-generated/
